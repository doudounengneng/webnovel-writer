# Webnovel-Writer LLM Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: openai | anthropic | mock
LLM_PROVIDER=mock

# API Keys (required if LLM_PROVIDER is not 'mock')
LLM_API_KEY=

# =============================================================================
# Model Configuration (optional - uses defaults if not set)
# =============================================================================
# OpenAI models: gpt-4o, gpt-4o-mini, gpt-4-turbo, o3-mini
# Anthropic models: claude-opus-4-20250514, claude-sonnet-4-20250514
# LLM_MODEL=gpt-4o

# =============================================================================
# Custom Base URL (optional - for proxy or alternative endpoints)
# =============================================================================
# LLM_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Generation Parameters
# =============================================================================
# Temperature: 0.0 (focused) to 1.0 (creative), default: 0.7
# LLM_TEMPERATURE=0.7

# Max tokens per response, default: 4096
# LLM_MAX_TOKENS=4096

# =============================================================================
# Usage Examples
# =============================================================================

# Example 1: Using OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Example 2: Using Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514

# Example 3: Using mock (for testing without API calls)
# LLM_PROVIDER=mock
